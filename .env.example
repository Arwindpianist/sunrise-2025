# =============================================================================
# Sunrise / Sunset monorepo — copy to .env.local (repo root and/or apps/sunrise-web)
# =============================================================================

# --- Database (Neon) — required ---
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# --- Auth (NextAuth) — required ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-secret

# Canonical public origin (emails, Stripe defaults, OG metadata)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Brand resolution (production) ---
# Option A: one deployment, two domains (recommended on Vercel)
# NEXT_PUBLIC_SUNRISE_HOSTS=sunrise-2025.com,www.sunrise-2025.com
# NEXT_PUBLIC_SUNSET_HOSTS=sunset-2025.com,www.sunset-2025.com

# Option B: single-brand Vercel project
# NEXT_PUBLIC_BRAND_ID=sunrise
# NEXT_PUBLIC_BRAND_ID=sunset

# Subscription API referer allowlist (optional; host lists are merged automatically)
# ALLOWED_APP_HOSTS=sunrise-2025.com,www.sunrise-2025.com,sunset-2025.com,www.sunset-2025.com

# Local / Vercel preview only — ignored when VERCEL_ENV=production
# IS_SUNSET=true
# NEXT_PUBLIC_IS_SUNSET=true

# Link between brands on marketing pages
# NEXT_PUBLIC_SUNRISE_URL=https://sunrise-2025.com

# --- Legacy Supabase (optional — compat layer uses Neon; leave empty in prod) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- SMTP (Zoho) — required for email sends ---
ZOHO_SMTP_HOST=smtp.zoho.com
ZOHO_SMTP_PORT=587
ZOHO_EMAIL_USER=marketing@sunrise-2025.com
ZOHO_EMAIL_PASSWORD=
OUTGOING_EMAIL_FROM=marketing@sunrise-2025.com

# --- Stripe ---
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Telegram / Discord / Slack (as needed) ---
# TELEGRAM_BOT_TOKEN=
# DISCORD_WEBHOOK_URL=

# --- Upgrade-phase feature flags ---
NEXT_PUBLIC_ENABLE_PWA_GLOBAL=false
NEXT_PUBLIC_ENABLE_GLOBAL_FLOATING_SOS=false
NEXT_PUBLIC_ENABLE_GLOBAL_HELP=true
NEXT_PUBLIC_ENABLE_GA=false
NEXT_PUBLIC_ENABLE_SOS=false
NEXT_PUBLIC_SHOW_UPGRADE_NOTICE=true
ENABLE_EMAIL_CRON=false
